FN         ::= "fn"
LET        ::= "let"
MUT        ::= "mut"
PRINT      ::= "println\!"
I32        ::= "i32"
RETURN     ::= "return"
ARROW      ::= "\->"
ASSIGN     ::= "="
SEMICOLON  ::= ";"
LBRACE     ::= "\{"
RBRACE     ::= "\}"
LPAREN     ::= "\("
RPAREN     ::= "\)"
COLON      ::= ":"
PLUS       ::= "\+"
IDENTIFIER ::= "[a-zA-Z_][a-zA-Z0-9_]*"
INTEGER    ::= "[0-9]+"
WHITESPACE ::= "[ \t\n]+"
