FN         ::= "fn"
LET        ::= "let"
MUT        ::= "mut"
PRINT      ::= "println"
TYPE       ::= "i32"
RETURN     ::= "return"
ARROW      ::= "\-"
ARROWB     ::= ">"
ASSIGN     ::= "="
SEMICOLON  ::= ";"
LBRACE     ::= "\{"
RBRACE     ::= "\}"
LPAREN     ::= "\("
RPAREN     ::= "\)"
COLON      ::= ":"
PLUS       ::= "\+"
EXCLAMATION ::= "!"
QUOTE      ::= "\""
IDENTIFIER ::= "[a-zA-Z_][a-zA-Z0-9_]*"
INTEGER    ::= "[0-9]+"
WHITESPACE ::= "[ \t\n]+"
